# ── Server-side secrets (never NEXT_PUBLIC_) ─────────────────────────────────

# Madhouse Wallet API key (mw_live_...). Obtain from business.madhousewallet.com/developers
WIDGET_API_KEY=mw_live_...

# Your Madhouse Wallet user ID. Obtain from business.madhousewallet.com/developers
WIDGET_USER_ID=

# Min 32-char secret for signing short-lived widget JWTs. Generate: node scripts/gen-secrets.js
WIDGET_JWT_SECRET=

# 32-byte hex secret for AES-256-GCM payload encryption. Generate: node scripts/gen-secrets.js
WIDGET_ENCRYPT_SECRET=

# Override upstream API base URL (optional — defaults to https://business.madhousewallet.com)
# WIDGET_API_BASE_URL=https://staging.madhousewallet.com

# reCAPTCHA v3 secret key (optional)
# RECAPTCHA_SECRET_KEY=

# Amazon SES for OTP email delivery (credentials provided via IAM role — no static keys needed)
AWS_REGION=us-east-1
# Verified SES sender address (must be verified in your AWS SES account)
SES_FROM_ADDRESS=noreply@yourdomain.com

# ── Browser-side public vars (NEXT_PUBLIC_ prefix) ───────────────────────────

# WalletConnect v2 project ID. Obtain from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# reCAPTCHA v3 site key (optional — badge hidden when omitted)
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Analytics measurement ID (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# WhatsApp support URL (optional — defaults to https://wa.me/14847739576)
# NEXT_PUBLIC_SUPPORT_WHATSAPP_URL=

# Canonical site URL (used for JSON-LD and OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
