# ── Required ──────────────────────────────────────────────────────────────────

# Madhouse Wallet API key — obtain from business.madhousewallet.com/developers
# Server-side only. NEVER prefix with NEXT_PUBLIC_
WIDGET_API_KEY=mw_live_...

# JWT secret — signs short-lived tokens that authenticate the widget frontend
# to the Next.js proxy. Prevents external callers from hitting the proxy directly.
# Server-side only. Min 32 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WIDGET_JWT_SECRET=f833544dbfdb62ef88c0d292ae9e621ec5b13a4ea9289acb06da5774223ea49d

# ── Optional ──────────────────────────────────────────────────────────────────

# Override the Madhouse Wallet API base URL (default: https://business.madhousewallet.com)
# Only needed when pointing at a staging or local instance.
# WIDGET_API_BASE_URL=https://business.madhousewallet.com
