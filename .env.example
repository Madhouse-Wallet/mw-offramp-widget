# Copy to .env and fill in values. Never commit .env.

# Min 32-char secret for signing short-lived widget JWTs.
# Generate: node scripts/gen-secrets.js
WIDGET_JWT_SECRET=

# 32-byte hex secret for AES-256-GCM payload encryption (browser <-> proxy).
# Generate: node scripts/gen-secrets.js
WIDGET_ENCRYPT_SECRET=

# Madhouse Wallet API key (mw_live_...). Never expose to the browser.
# Obtain from business.madhousewallet.com/developers
WIDGET_API_KEY=

# (Optional) Override upstream API base URL. Defaults to https://business.madhousewallet.com
# WIDGET_API_BASE_URL=

# (Optional) Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Obtain from analytics.google.com → Admin → Data Streams → your stream
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
